eval_results_all/Geant4/

# KS scaling: individual CSVs/counts summarised in ks_scaling_all.json
eval_scaling/ks_scaling_*.csv
eval_scaling/train_counts_*.txt
# Raw per-n subdirectories (large, regenerable from EOS)
eval_scaling/Photon_*/
eval_scaling/Pion_*/

