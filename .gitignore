# Python
__pycache__/
*.pyc
*.pyo
*.un~

# IDE
.vscode/

# Generated plots (regenerate with plot scripts)
plots/
profiling_plots/

# Evaluation result artifacts: large binaries and per-variable PNGs/PDFs
eval_results_all/**/*.hdf5
eval_results_all/**/*.png
eval_results_all/**/*.pdf
# Ignore raw feature .npz files but keep hist/*.npz (needed by plot_summary.py)
eval_results_all/**/*.npz
!eval_results_all/**/hist/*.npz
# Individual text result files (summarised in metrics_summary.json)
eval_results_all/**/metrics.txt
eval_results_all/**/sep_power.txt
